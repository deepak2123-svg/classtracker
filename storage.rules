rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/roles/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/roles/$(request.auth.uid)).data.role
          in ["manager", "admin", "group_admin", "institute_admin"];
    }

    match /sampleReports/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin()
        && fileName.matches('^[A-Za-z0-9_-]+\\.pdf$')
        && request.resource.size > 0
        && request.resource.size <= 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow delete: if isAdmin();
    }
  }
}

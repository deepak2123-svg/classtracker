rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{uid}/appdata/{doc} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /roles/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin() || request.auth.uid == uid;
    }

    match /teachers/{uid} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /feedbackThreads/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == uid &&
          request.resource.data.teacherUid == uid &&
          request.resource.data.lastSenderRole == "teacher" &&
          request.resource.data.status == "open"
        )
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == uid &&
          request.resource.data.teacherUid == resource.data.teacherUid &&
          request.resource.data.teacherUid == uid &&
          request.resource.data.lastSenderRole == "teacher" &&
          request.resource.data.status == "open" &&
          request.resource.data.unreadByTeacher == resource.data.unreadByTeacher
        ) ||
        (
          request.auth.uid == uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["unreadByTeacher"]) &&
          request.resource.data.unreadByTeacher == 0
        )
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if isSignedIn() && (
          isAdmin() ||
          (
            request.auth.uid == uid &&
            request.resource.data.senderUid == uid &&
            request.resource.data.senderRole == "teacher" &&
            request.resource.data.body is string &&
            request.resource.data.body.size() > 0 &&
            request.resource.data.body.size() <= 2000
          )
        );
        allow update, delete: if false;
      }
    }

    match /config/{doc} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    match /syllabusTemplates/{templateId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();

      match /versions/{versionId} {
        allow read:  if isAdmin();
        allow create: if isAdmin();
        allow update, delete: if false;
      }
    }

    match /publishedSyllabi/{templateId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    match /invites/{token} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn();
    }
  }
}

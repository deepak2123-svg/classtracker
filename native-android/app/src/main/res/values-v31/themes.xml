<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ledgr" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/ledgr_loading_background</item>
        <item name="android:windowSplashScreenBackground">@color/ledgr_loading_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/ledgr_loading_background</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/ledgr_loading_background</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
